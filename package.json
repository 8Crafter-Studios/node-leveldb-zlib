{
    "name": "@8crafter/leveldb-zlib",
    "version": "2.0.0",
    "description": "Node.js and WebAssembly bindings for LevelDB with zlib",
    "main": "index_node.js",
    "module": "index_wasm.js",
    "scripts": {
        "checkEnv": "node buildChecks.js",
        "install": "node buildChecks.js",
        "prepare": "tsc --build",
        "build": "tsc --build",
        "postci": "node helpers/postCI.js",
        "prepublish": "cd helpers && node npmPublish.js",
        "fix": "ts-standard --fix",
        "test": "npm run build && mocha"
    },
    "author": "extremeheat",
    "license": "ISC",
    "repository": {
        "type": "git",
        "url": "git://github.com/8Crafter-Studios/node-leveldb-zlib.git"
    },
    "dependencies": {
        "@emnapi/core": "^1.11.1",
        "@emnapi/runtime": "^1.11.1",
        "bindings": "^1.5.0",
        "cmake-js": "^7.3.1",
        "debug": "^4.3.1",
        "node-addon-api": "^6.1.0"
    },
    "devDependencies": {
        "@8crafter/leveldb-zlib": "file:.",
        "@types/node": "^14.14.16",
        "emnapi": "^1.11.1",
        "mocha": "^8.4.0",
        "ts-node": "^9.1.1",
        "ts-standard": "^10.0.0",
        "typescript": "^4.1.3"
    },
    "exports": {
        ".": {
            "default": "./index_node.js",
            "require": "./index_node.js",
            "node": "./index_node.js",
            "module-sync": "./index_node.js",
            "types": "./index_node.d.ts"
        },
        "./node": {
            "default": "./index_node.js",
            "types": "./index_node.d.ts"
        },
        "./wasm": {
            "default": "./index_wasm.js",
            "types": "./index_wasm.d.ts"
        },
        "./*": "./*"
    }
}
